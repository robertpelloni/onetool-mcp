{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.beycom/onetool-mcp",
  "version": "dev",
  "title": "OneTool MCP",
  "description": "🧿One MCP, unlimited tools. Execute Python code with access to curated tool packs.",
  "repository": {
    "url": "https://github.com/beycom/onetool-mcp",
    "source": "github"
  },
  "websiteUrl": "https://onetool.beycom.online",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "onetool-mcp",
      "version": "dev",
      "transport": { "type": "stdio" },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "positional", "value": "onetool" }
      ],
      "packageArguments": [
        { "type": "positional", "value": "serve" }
      ]
    }
  ]
}
