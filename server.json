{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.beycom/onetool-mcp",
  "version": "1.0.0rc3",
  "title": "OneTool MCP",
  "description": "🧿 One MCP for developers - No tool tax, no context rot. 100+ tools including Brave, Gemini, Context7, Version Checker, Excel, File Ops, Database, Chrome DevTools.",
  "repository": {
    "url": "https://github.com/beycom/onetool-mcp",
    "source": "github"
  },
  "websiteUrl": "https://onetool.beycom.online",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "onetool-mcp",
      "version": "1.0.0rc3",
      "transport": { "type": "stdio" },
      "runtimeHint": "uvx",
      "runtimeArguments": [
        { "type": "positional", "value": "onetool" }
      ],
      "packageArguments": [
        { "type": "positional", "value": "serve" }
      ]
    }
  ]
}
